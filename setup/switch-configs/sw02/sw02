! ceos2 — leaf (data-tier gateway)
!
hostname ceos2
!
username admin privilege 15 role network-admin secret 0 admin
!
aaa authorization exec default local
!
ip routing
!
ip access-list ZTA-DATA-TIER
   10 permit tcp 10.20.0.0/24 10.30.0.0/24 eq 5432
   20 permit tcp 10.30.0.0/24 eq 5432 10.20.0.0/24 established
   100 deny ip any 10.30.0.0/24
   200 permit ip any any
!
interface Management0
   no shutdown
!
interface Ethernet2
   no switchport
   ip address 10.10.0.2/24
   no shutdown
!
interface Ethernet3
   no switchport
   ip address 10.30.0.1/24
   no shutdown
!
ip route 10.20.0.0/24 10.10.0.1
!
management api http-commands
   protocol http
   no shutdown
!
management ssh
   idle-timeout 120
!
end
